---
machine:
  certSANs:
${CERT_SANS}
  network:
    nameservers:
      - 1.1.1.1
      - 9.9.9.9
      - 2606:4700:4700::1111
      - 2620:fe::fe
  sysctls:
    net.ipv4.ip_forward: "1"
    net.ipv6.conf.all.forwarding: "1"
  kubelet:
    nodeIP:
      validSubnets:
${KUBELET_NODEIP_CIDRS}
    extraArgs:
      rotate-server-certificates: true